# 문화공공데이터광장 독립서점 API (서버 전용)
CULTURE_API_KEY=your_culture_api_service_key

# 문화공공데이터광장 카페가 있는 서점 API (서버 전용)
CAFE_BOOKSTORE_API_KEY=your_cafe_bookstore_api_service_key

# 문화공공데이터광장 중고서점 API (서버 전용)
USED_BOOKSTORE_API_KEY=your_used_bookstore_api_service_key

# 공공데이터포털 가족단위 문화시설 API (서버 전용)
FAMILY_CULTURE_API_KEY=your_family_culture_api_service_key

# 카카오맵 JavaScript 키 (클라이언트 노출)
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=your_kakao_javascript_key

# Supabase 리뷰 데이터베이스 (클라이언트 노출 가능한 public key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_key
# Supabase 대시보드에서 publishable key 이름으로 표시되면 아래 이름도 사용 가능
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# 리뷰 테이블 자동 등록용 (서버/로컬 스크립트 전용, GitHub Secrets에는 넣지 마세요)
SUPABASE_DB_PASSWORD=your_supabase_database_password
# Supabase Connect 화면의 리전 (예: ap-northeast-2). 없으면 자동으로 여러 리전을 시도합니다.
SUPABASE_DB_REGION=ap-northeast-2
# 또는 Connect > Session pooler URI 전체를 직접 지정할 수도 있습니다.
# SUPABASE_DB_URL=postgresql://postgres.your-project-ref:password@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres
